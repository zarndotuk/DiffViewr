{
  "name": "diffviewr",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "css:build": "tailwindcss -i ./app/globals.css -o ./app/generated.css --minify",
    "css:watch": "tailwindcss -i ./app/globals.css -o ./app/generated.css --watch",
    "dev": "npm run css:build && concurrently --kill-others-on-fail \"npm run css:watch\" \"next dev\"",
    "build": "npm run css:build && next build",
    "postbuild": "next-sitemap",
    "analyze:bundle": "node scripts/report-route-bundles.mjs",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@types/js-yaml": "^4.0.9",
    "js-yaml": "^4.1.1",
    "next": "^16.2.9",
    "posthog-js": "^1.386.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shiki": "^3.7.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^10.0.3",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.9",
    "next-sitemap": "^4.2.3",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.7.0"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
